<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>互動式白板便利貼</title>
    <style>
        /* 全域樣式：打造白板背景 */
        body {
            margin: 0;
            padding: 0;
            background-color: #f4f5f7;
            background-image: 
                radial-gradient(#e0e2e6 1.5px, transparent 1.5px), 
                radial-gradient(#e0e2e6 1.5px, #f4f5f7 1.5px);
            background-size: 30px 30px;
            background-position: 0 0, 15px 15px;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
        }

        /* 頂部功能列 */
        .controls {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
            background: rgba(255, 255, 255, 0.85);
            padding: 10px 20px;
            border-radius: 30px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            backdrop-filter: blur(5px);
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .btn {
            background-color: #2563eb;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s, transform 0.1s;
        }

        .btn:hover {
            background-color: #1d4ed8;
        }

        .btn:active {
            transform: scale(0.95);
        }

        .hint {
            font-size: 12px;
            color: #64748b;
        }

        /* 白板畫布區域 */
        #board {
            width: 100%;
            height: 100%;
            position: relative;
        }

        /* 便利貼主體樣式 */
        .note {
            position: absolute;
            width: 180px;
            min-height: 180px;
            padding: 15px;
            box-sizing: border-box;
            box-shadow: 2px 4px 10px rgba(0,0,0,0.12);
            cursor: move;
            user-select: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.1s, box-shadow 0.1s;
            border-radius: 2px;
        }

        /* 模擬手寫感與便利貼微翹效果 */
        .note::after {
            content: "";
            position: absolute;
            bottom: 0;
            right: 2px;
            width: 30px;
            height: 8px;
            box-shadow: 5px 12px 10px rgba(0,0,0,0.15);
            transform: rotate(3deg);
            z-index: -1;
        }

        /* 拖曳中的樣式 */
        .note.dragging {
            transform: scale(1.03) rotate(-1deg);
            box-shadow: 5px 15px 25px rgba(0,0,0,0.18);
            z-index: 999 !important;
        }

        /* 文字內容區 */
        .note-content {
            width: 100%;
            height: 100%;
            border: none;
            background: transparent;
            resize: none;
            font-size: 15px;
            line-height: 1.5;
            color: #334155;
            outline: none;
            cursor: move;
            word-break: break-all;
            white-space: pre-wrap;
        }

        /* 當雙擊進入編輯狀態時 */
        .note-content.editing {
            cursor: text;
        }

        /* 刪除按鈕 */
        .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: rgba(0,0,0,0.06);
            color: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            opacity: 0;
            transition: opacity 0.2s, background 0.2s;
        }

        .note:hover .delete-btn {
            opacity: 1;
        }

        .delete-btn:hover {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
        }
    </style>
</head>
<body>

    <div class="controls">
        <button class="btn" id="add-btn">+ 新增便利貼</button>
        <span class="hint">💡 操作說明：拖曳頂端移動｜雙擊文字編輯｜滑鼠移到右上角可刪除</span>
    </div>

    <div id="board"></div>

    <script>
        const board = document.getElementById('board');
        const addBtn = document.getElementById('add-btn');
        
        // 便利貼粉嫩色系庫
        const colors = [
            '#fff9db', // 柔黃
            '#e7f5ff', // 淡藍
            '#e6fcf5', // 薄荷綠
            '#fff0f6', // 粉紅
            '#f3f0ff', // 薰衣草紫
            '#fff4e6'  // 暖橘
        ];

        let zIndexCounter = 1;

        // 初始化：先隨機生出兩張作為範例
        createNote('歡迎使用數位白板！雙擊我可以修改內容。', 200, 150);
        createNote('把你的注意事項寫在這裡，自由拖曳擺放吧！', 420, 250);

        // 點擊按鈕新增
        addBtn.addEventListener('click', () => {
            // 在畫面中心附近隨機產生
            const x = Math.random() * (window.innerWidth - 250) + 50;
            const y = Math.random() * (window.innerHeight - 300) + 100;
            createNote('新注意事項...', x, y);
        });

        // 建立便利貼的函式
        function createNote(text = '', left = 100, top = 100) {
            const note = document.createElement('div');
            note.className = 'note';
            note.style.left = `${left}px`;
            note.style.top = `${top}px`;
            note.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            note.style.zIndex = zIndexCounter++;

            // 隨機微小旋轉角度，增加擬真手寫感
            const randomRotate = (Math.random() * 4 - 2).toFixed(1); // -2 到 2 度
            note.style.transform = `rotate(${randomRotate}deg)`;

            // 內部 HTML 結構
            note.innerHTML = `
                <div class="delete-btn">✕</div>
                <div class="note-content" contenteditable="false">${text}</div>
            `;

            const contentNode = note.querySelector('.note-content');
            const deleteBtn = note.querySelector('.delete-btn');

            // --- 功能 1：雙擊編輯文字 ---
            contentNode.addEventListener('dblclick', (e) => {
                contentNode.contentEditable = "true";
                contentNode.classList.add('editing');
                contentNode.focus();
                // 編輯時暫時切換全選文字
                document.execCommand('selectAll', false, null);
            });

            // 結束編輯（失去焦點時）
            contentNode.addEventListener('blur', () => {
                contentNode.contentEditable = "false";
                contentNode.classList.remove('editing');
            });

            // 阻擋編輯狀態下的拖曳事件，避免選取文字時跑掉
            contentNode.addEventListener('mousedown', (e) => {
                if (contentNode.contentEditable === "true") {
                    e.stopPropagation(); 
                }
            });

            // --- 功能 2：滑鼠拖曳 (Drag and Drop) ---
            let isDragging = false;
            let startX, startY;
            let startLeft, startTop;

            note.addEventListener('mousedown', (e) => {
                // 如果是在點擊刪除或編輯文字，不觸發拖曳
                if (e.target === deleteBtn || contentNode.contentEditable === "true") return;

                isDragging = true;
                note.classList.add('dragging');
                note.style.zIndex = zIndexCounter++; // 點擊時移到最上層

                // 記錄滑鼠點擊時的初始座標與便利貼位置
                startX = e.clientX;
                startY = e.clientY;
                startLeft = parseInt(note.style.left);
                startTop = parseInt(note.style.top);

                // 全局監聽滑鼠移動與放開事件
                document.addEventListener('mousemove', onMouseMove);
                document.addEventListener('mouseup', onMouseUp);
            });

            function onMouseMove(e) {
                if (!isDragging) return;
                
                // 計算位移量
                const deltaX = e.clientX - startX;
                const deltaY = e.clientY - startY;

                // 新的位置
                let newLeft = startLeft + deltaX;
                let newTop = startTop + deltaY;

                // 邊界限制（不讓便利貼飛出瀏覽器視窗外）
                if (newLeft < 0) newLeft = 0;
                if (newTop < 0) newTop = 0;
                if (newLeft > window.innerWidth - note.offsetWidth) newLeft = window.innerWidth - note.offsetWidth;
                if (newTop > window.innerHeight - note.offsetHeight) newTop = window.innerHeight - note.offsetHeight;

                note.style.left = `${newLeft}px`;
                note.style.top = `${newTop}px`;
            }

            function onMouseUp() {
                isDragging = false;
                note.classList.remove('dragging');
                document.removeEventListener('mousemove', onMouseMove);
                document.removeEventListener('mouseup', onMouseUp);
            }

            // --- 功能 3：刪除便利貼 ---
            deleteBtn.addEventListener('click', () => {
                note.remove();
            });

            // 將便利貼放到白板上
            board.appendChild(note);
        }

        // 視窗大小改變時，修正可能超出螢幕的便利貼
        window.addEventListener('resize', () => {
            const notes = document.querySelectorAll('.note');
            notes.forEach(note => {
                let left = parseInt(note.style.left);
                let top = parseInt(note.style.top);
                if (left > window.innerWidth - note.offsetWidth) {
                    note.style.left = `${window.innerWidth - note.offsetWidth}px`;
                }
                if (top > window.innerHeight - note.offsetHeight) {
                    note.style.top = `${window.innerHeight - note.offsetHeight}px`;
                }
            });
        });
    </script>
</body>
</html>
